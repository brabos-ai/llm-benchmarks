---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ModelProfile from "../../components/ModelProfile.astro";
import { getProvider } from "../../data/providers";
import { fetchAllModels } from "../../data/openrouter";
import modelsData from "../../data/models.json";

export async function getStaticPaths() {
  // Try to fetch OpenRouter data for all models.
  // If fetch fails, all openrouterData will be null (graceful degradation).
  let openrouterMap = new Map();
  try {
    const slugs = modelsData.models.map((m) => m.openrouterSlug);
    openrouterMap = await fetchAllModels(slugs);
  } catch (_) {
    // graceful degradation — openrouterData will be null for all models
  }

  const allModelsData = modelsData.models as any[];

  return modelsData.models.map((model) => {
    const provider = getProvider(model.provider as Parameters<typeof getProvider>[0]);
    const openrouterData = openrouterMap.get(model.openrouterSlug) ?? null;

    // Compute family members: all non-obsolete models in same family (including current)
    const currentFamily = (model as any).family;
    const familyMembers = currentFamily
      ? allModelsData.filter(
          (m: any) => m.family === currentFamily && !m.isObsolete
        )
      : [];

    return {
      params: { slug: model.id },
      props: { model, provider, openrouterData, familyMembers },
    };
  });
}

const { model, provider, openrouterData, familyMembers } = Astro.props;
---

<!-- ECharts CDN for radar chart on profile page -->
<script is:inline src="https://cdn.jsdelivr.net/npm/echarts@5.6.0/dist/echarts.min.js"></script>

<BaseLayout title={`${model.name} | LLM Benchmarks`}>
  <main class="container">
    <ModelProfile model={model} provider={provider} openrouterData={openrouterData} familyMembers={familyMembers} />
  </main>
</BaseLayout>
