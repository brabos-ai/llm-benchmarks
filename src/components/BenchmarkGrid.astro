---
import { benchmarks, translations } from "../data/home";

const catOrder = ["agentic", "multiagent", "coding", "general", "reasoning"] as const;
---

<p class="section-label">// <span data-i18n="sectionBench">{translations.en.sectionBench}</span></p>

<div class="grid" id="benchGrid">
  {
    benchmarks.map((benchmark) => {
      const entries = Object.entries(benchmark.relevanceScores) as [string, number][];
      const primaryCat = entries.reduce((best, curr) => (curr[1] > best[1] ? curr : best))[0];

      return (
        <article class="card" data-cats={benchmark.categories.join(",")} data-primary={primaryCat}>
          <div class="card-top">
            <span class="bench-name">{benchmark.name}</span>
            <div class="tags">
              {benchmark.tagKeys.map((tagKey) => {
                const className =
                  tagKey === "tagAgentic" ? "agentic"
                  : tagKey === "tagCoding" ? "coding"
                  : tagKey === "tagGeneral" ? "general"
                  : tagKey === "tagReasoning" ? "reasoning"
                  : "multiagent";

                return (
                  <span class:list={["tag", className]} data-i18n={tagKey}>
                    {translations.en[tagKey]}
                  </span>
                );
              })}
            </div>
          </div>

          <p class="bench-desc" data-i18n={benchmark.descriptionKey}>
            {translations.en[benchmark.descriptionKey]}
          </p>

          <p class="bench-what">
            <strong data-i18n="measures">{translations.en.measures}</strong>{" "}
            <span data-i18n={benchmark.whatKey}>{translations.en[benchmark.whatKey]}</span>
          </p>

          <div class="relevance-grid">
            <span class="relevance-label" data-i18n="relevance">{translations.en.relevance}</span>
            <div class="relevance-rows">
              {catOrder.map((cat) => {
                const score = benchmark.relevanceScores[cat];
                return (
                  <div class="rel-row">
                    <span class="rel-dot" style={"background: var(--" + cat + ")"}></span>
                    <span class="rel-name" data-i18n={cat}>{translations.en[cat]}</span>
                    <div class="rel-pips">
                      {Array.from({ length: 5 }, (_, i) => (
                        <div class:list={["pip", { ["lit-" + cat]: i < score }]}></div>
                      ))}
                    </div>
                    <span class="rel-score">{score > 0 ? score : ""}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </article>
      );
    })
  }
</div>
