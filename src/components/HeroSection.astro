---
import { benchmarks, categories, translations } from "../data/home";

const benchmarkCount = benchmarks.length;
const categoryCount = categories.filter((c) => c.id !== "all").length;
---

<header>
  <p class="eyebrow">// <span data-i18n="eyebrow">{translations.en.eyebrow}</span></p>
  <h1 data-i18n="h1">{translations.en.h1}</h1>
  <p class="subtitle" data-i18n="subtitle">{translations.en.subtitle}</p>
  <div class="hero-stats">
    <div class="hero-stat">
      <span class="hero-stat-number">{benchmarkCount}</span>
      <span class="hero-stat-label" data-i18n="statBenchmarks">benchmarks</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-number">{categoryCount}</span>
      <span class="hero-stat-label" data-i18n="statCategories">categorias</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-number">2</span>
      <span class="hero-stat-label" data-i18n="statLanguages">idiomas</span>
    </div>
  </div>
</header>
